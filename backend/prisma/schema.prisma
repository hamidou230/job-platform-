// Plateforme de stages et d'emplois pour étudiants
// Prisma + MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------- ENUMS ----------------

enum Role {
  STUDENT
  COMPANY
  ADMIN
}

enum OfferType {
  INTERNSHIP // Stage
  JOB        // Emploi
  ALTERNANCE // Alternance
  PART_TIME  // Temps partiel
}

enum OfferStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ExperienceLevel {
  JUNIOR
  INTERMEDIATE
  SENIOR
}

enum ApplicationStatus {
  PENDING   // En attente
  REVIEWED  // Examinée
  ACCEPTED  // Acceptée
  REJECTED  // Refusée
}

enum NotificationType {
  APPLICATION
  OFFER
  SYSTEM
}

// ---------------- MODELS ----------------

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student       Student?
  company       Company?
  notifications Notification[]

  @@map("users")
}

model Student {
  id             String    @id @default(uuid())
  userId         String    @unique
  firstName      String
  lastName       String
  phone          String?
  university      String?
  fieldOfStudy   String?
  graduationYear Int?
  bio            String?   @db.Text
  skills         String?   @db.Text // compétences séparées par des virgules
  cvUrl          String?
  avatarUrl      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  favorites    Favorite[]

  @@index([fieldOfStudy])
  @@map("students")
}

model Company {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  description String?  @db.Text
  website     String?
  logoUrl     String?
  industry    String?
  location    String?
  size        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers Offer[]

  @@index([industry])
  @@map("companies")
}

model Offer {
  id              String          @id @default(uuid())
  companyId       String
  title           String
  description     String          @db.Text
  type            OfferType       @default(INTERNSHIP)
  location        String?
  isRemote        Boolean         @default(false)
  salaryMin       Int?
  salaryMax       Int?
  requiredSkills  String?         @db.Text // séparées par des virgules
  experienceLevel ExperienceLevel @default(JUNIOR)
  status          OfferStatus     @default(OPEN)
  deadline        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  favorites    Favorite[]

  @@index([type])
  @@index([status])
  @@index([location])
  @@index([companyId])
  @@map("offers")
}

model Application {
  id          String            @id @default(uuid())
  studentId   String
  offerId     String
  status      ApplicationStatus @default(PENDING)
  coverLetter String?           @db.Text
  cvUrl       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([studentId, offerId]) // une seule candidature par offre
  @@index([status])
  @@map("applications")
}

model Favorite {
  id        String   @id @default(uuid())
  studentId String
  offerId   String
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([studentId, offerId])
  @@map("favorites")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String           @db.Text
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
